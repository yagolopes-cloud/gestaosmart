# Banco local (ajustes/historico) - SQLite
DB_URL="file:./prisma/dev.db"

# Conexao Nomus (MySQL) - somente leitura. Senha: # = %23, @ = %40
NOMUS_DB_URL="mysql://usuario:senha@host:3306/weberp_soaco"

APP_PORT=3000
# Acesso externo 170.84.146.147: use APP_PORT=5174 (porta liberada no MikroTik) e FRONTEND_ORIGIN abaixo.
NODE_ENV=production
JWT_SECRET=troque-isto-por-uma-chave-segura

# CORS - URL do frontend ao publicar em outro IP (ex.: 170.84.146.147)
# FRONTEND_ORIGIN=http://170.84.146.147:5174

# Cookies em HTTPS: defina COOKIE_SECURE=true. Em HTTP (IP local/externo sem HTTPS) deixe sem definir ou false.
# COOKIE_SECURE=true

# Evolution API 2.3.6 (JPG Soluções) - ver backend/docs/EVOLUTION-API-2.3.6.md
EVOLUTION_API_URL=https://api.jpgsolucoesinformatica.com.br
EVOLUTION_API_KEY=sua-apikey
EVOLUTION_API_INSTANCE=
EVOLUTION_WHATSAPP_NUMBER=
