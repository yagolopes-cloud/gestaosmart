# ========== Banco de dados ==========
# PostgreSQL (exemplo):
DB_URL=postgresql://USUARIO:SENHA@HOST:PORT/DB?schema=public

# SQL Server (exemplo - troque provider no prisma/schema.prisma para "sqlserver"):
# DB_URL="mssql://USUARIO:SENHA@HOST:PORT?database=DB&encrypt=true"

# ========== Aplicação ==========
APP_PORT=3000
NODE_ENV=development

# Segredo para assinatura do JWT (troque em produção)
JWT_SECRET=troque-isto-por-uma-chave-segura

# Origem permitida para CORS (frontend)
# FRONTEND_ORIGIN=http://localhost:5173
